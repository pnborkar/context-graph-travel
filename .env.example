# Hospitality Context Graph Application
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# WARNING: Change all default credentials before deploying to any
# network-accessible environment. Never commit real credentials to git.

# Memory backend: 'nams' (default — hosted) or 'bolt' (self-hosted Neo4j)
MEMORY_BACKEND=bolt

# Self-hosted Neo4j (Bolt)
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here

# Memory layer LLM + embedding provider (LiteLLM-style strings, optional).
# Native providers are resolved first; everything else routes through LiteLLM.
#
# Examples (uncomment one):
# MEMORY_LLM=anthropic/claude-haiku-4-5             # Anthropic native
# MEMORY_LLM=openai/gpt-4o-mini                     # OpenAI native
# MEMORY_LLM=bedrock/anthropic.claude-3-haiku-20240307-v1:0  # AWS Bedrock via LiteLLM
# MEMORY_LLM=vertex_ai/gemini-1.5-flash             # Google Vertex AI via LiteLLM
# MEMORY_LLM=ollama/llama3                          # Local Ollama via LiteLLM
MEMORY_LLM=
# MEMORY_EMBEDDING=sentence-transformers/all-MiniLM-L6-v2   # Local (default fallback)
# MEMORY_EMBEDDING=openai/text-embedding-3-small            # OpenAI native
MEMORY_EMBEDDING=

# LLM API Keys (for the agent — set the one your selected framework needs)
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=  # Optional: enables OpenAI embeddings for conversation memory (local sentence-transformers used by default)
GOOGLE_API_KEY=your-google-api-key-here  # Required for google-adk framework
# ANTHROPIC_MODEL=claude-sonnet-4-20250514  # Override default model for Claude Agent SDK

# Application
DOMAIN_ID=hospitality
SESSION_STRATEGY=per_conversation
BACKEND_PORT=8000
FRONTEND_PORT=3000

# CORS — comma-separated origins allowed for frontend (default: http://localhost:3000)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Suppress HuggingFace Hub warnings (set HF_TOKEN for higher rate limits)
HF_HUB_DISABLE_TELEMETRY=1
# HF_TOKEN=your-huggingface-token-here
